# GitHub
GITHUB_TOKEN=ghp_your_personal_access_token
GITHUB_API_RATE_LIMIT=5000

# Database
DATABASE_URL=postgresql://bounty:bounty@localhost:5432/bugbountyhunter

# Redis
REDIS_URL=redis://localhost:6379

# Bug Bounty Platforms
HACKERONE_API_TOKEN=
HACKERONE_API_USERNAME=
BUGCROWD_API_TOKEN=
INTIGRITI_API_TOKEN=

# AI/LLM (optional - for triage)
OPENAI_API_KEY=

# Scanning
SCAN_CONCURRENCY=3
REPO_CACHE_DIR=./data/repos
MAX_REPO_SIZE_MB=500
SCAN_TIMEOUT_MS=300000

# Logging
LOG_LEVEL=info
NODE_ENV=development
