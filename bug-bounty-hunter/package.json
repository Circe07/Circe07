{
  "name": "bug-bounty-hunter",
  "version": "0.1.0",
  "description": "Automated security vulnerability discovery system for Bug Bounty programs",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "cli": "tsx src/cli.ts",
    "lint": "eslint src/ --ext .ts",
    "lint:fix": "eslint src/ --ext .ts --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:studio": "prisma studio"
  },
  "keywords": [
    "security",
    "bug-bounty",
    "vulnerability-scanner",
    "sast",
    "github"
  ],
  "author": "Alejandro Perez Abreu",
  "license": "MIT",
  "dependencies": {
    "@octokit/rest": "^21.0.0",
    "@prisma/client": "^6.0.0",
    "axios": "^1.7.0",
    "bullmq": "^5.0.0",
    "commander": "^12.0.0",
    "dotenv": "^16.4.0",
    "fastify": "^5.0.0",
    "ioredis": "^5.4.0",
    "ora": "^8.0.0",
    "p-limit": "^6.0.0",
    "pino": "^9.0.0",
    "pino-pretty": "^11.0.0",
    "simple-git": "^3.27.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "prisma": "^6.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
